# PickMeUp — Environment Variables
# In development: copy to .env.local
# In Netlify: add via Site Settings → Environment Variables

# Set to 'true' in dev to skip the PWA install gate
# Set to 'false' (or omit) in production
VITE_BYPASS_INSTALL_GATE=true

# Supabase — get these from Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Admin login code
VITE_ADMIN_CODE=ADMIN

# Phase 7 — Web Push (add later)
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
